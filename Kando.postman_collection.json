{
  "info": {
    "name": "Kando API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",   "value": "http://localhost:8080" },
    { "key": "token",     "value": "" },
    { "key": "boardId",   "value": "" },
    { "key": "taskId",    "value": "" },
    { "key": "memberId",  "value": "" },
    { "key": "userId",    "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  pm.collectionVariables.set('userId', res.data.userId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jimmy@example.com\",\n  \"password\": \"password123\",\n  \"displayName\": \"Jimmy\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  pm.collectionVariables.set('userId', res.data.userId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jimmy@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Boards",
      "item": [
        {
          "name": "Create Board",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('boardId', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/boards",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mi primer tablero\",\n  \"description\": \"Tablero de prueba para Kando\"\n}"
            }
          }
        },
        {
          "name": "Get My Boards",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/boards"
          }
        },
        {
          "name": "Get Board by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/boards/{{boardId}}"
          }
        },
        {
          "name": "Update Board",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/boards/{{boardId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tablero actualizado\",\n  \"description\": \"Nueva descripción\"\n}"
            }
          }
        },
        {
          "name": "Delete Board",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/boards/{{boardId}}"
          }
        }
      ]
    },
    {
      "name": "Board Members",
      "item": [
        {
          "name": "Get Members",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/boards/{{boardId}}/members"
          }
        },
        {
          "name": "Invite Member",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.membershipId) {",
                  "  pm.collectionVariables.set('memberId', res.data.membershipId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/boards/{{boardId}}/members",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"<otro-user-id>\",\n  \"role\": \"MEMBER\"\n}"
            }
          }
        },
        {
          "name": "Change Member Role",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/boards/{{boardId}}/members/{{memberId}}/role?role=ADMIN",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards", "{{boardId}}", "members", "{{memberId}}", "role"],
              "query": [{ "key": "role", "value": "ADMIN" }]
            }
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/boards/{{boardId}}/members/{{memberId}}"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task (root)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('taskId', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Primera tarea\",\n  \"description\": \"Descripción de la tarea\",\n  \"boardId\": \"{{boardId}}\",\n  \"positionIndex\": \"m\",\n  \"priority\": \"MEDIUM\"\n}"
            }
          }
        },
        {
          "name": "Create Subtask",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Subtarea\",\n  \"description\": \"Subtarea de la primera tarea\",\n  \"boardId\": \"{{boardId}}\",\n  \"parentId\": \"{{taskId}}\",\n  \"positionIndex\": \"m\",\n  \"priority\": \"HIGH\",\n  \"dueDate\": \"2026-05-01T00:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Get Tasks by Board",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tasks/board/{{boardId}}"
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}"
          }
        },
        {
          "name": "Get Subtasks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}/subtasks"
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tarea actualizada\",\n  \"status\": \"DOING\",\n  \"priority\": \"HIGH\",\n  \"version\": 0\n}"
            }
          }
        },
        {
          "name": "Complete Task",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DONE\",\n  \"version\": 1\n}"
            }
          }
        },
        {
          "name": "Update Task - Conflict (wrong version)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Esto debería dar 409\",\n  \"version\": 999\n}"
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/tasks/{{taskId}}"
          }
        }
      ]
    },
    {
      "name": "Sync",
      "item": [
        {
          "name": "First Sync (full pull)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/sync/{{boardId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lastSyncAt\": null,\n  \"tasks\": []\n}"
            }
          }
        },
        {
          "name": "Sync - Push local changes",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/sync/{{boardId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lastSyncAt\": \"2026-04-12T00:00:00Z\",\n  \"tasks\": [\n    {\n      \"id\": \"01HZZZZZZZZZZZZZZZZZZZZZZ1\",\n      \"operation\": \"CREATE\",\n      \"title\": \"Tarea creada offline\",\n      \"description\": \"Creada sin conexión\",\n      \"positionIndex\": \"m\",\n      \"priority\": \"MEDIUM\",\n      \"clientUpdatedAt\": \"2026-04-12T10:00:00Z\"\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Sync - Update with conflict check",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/sync/{{boardId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lastSyncAt\": \"2026-04-12T00:00:00Z\",\n  \"tasks\": [\n    {\n      \"id\": \"{{taskId}}\",\n      \"operation\": \"UPDATE\",\n      \"title\": \"Editado offline\",\n      \"status\": \"DOING\",\n      \"version\": 0,\n      \"clientUpdatedAt\": \"2026-04-12T11:00:00Z\"\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Sync - Delete offline",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/sync/{{boardId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lastSyncAt\": \"2026-04-12T00:00:00Z\",\n  \"tasks\": [\n    {\n      \"id\": \"{{taskId}}\",\n      \"operation\": \"DELETE\",\n      \"version\": 0\n    }\n  ]\n}"
            }
          }
        }
      ]
    }
  ]
}
